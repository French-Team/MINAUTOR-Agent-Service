{
    "name": "minautor-agent-service",
    "version": "0.1.0",
    "license": "MIT",
    "description": "System Agentic inspired by Codebuff",
    "type": "module",
    "main": "dist/engine.js",
    "scripts": {
        "prebuild": "npx tsx src/lint-regex.ts",
        "build": "tsc",
        "start": "node dist/cli.js",
        "cli": "npm run build && npm start",
        "final": "cls && npm run build && npm start",
        "test:unit": "node dist/test/unit-tests.js",
        "test:e2e": "node dist/test/e2e-flow-test.js && node dist/test/e2e-orchestrateur-flow-test.js",
        "test:load": "npx tsx src/test/load-tests.ts",
        "test:ci": "npm run build && npm run validate:all && npm run lint && node dist/test/unit-tests.js && node dist/test/test.js && npm run test:eslint-rules",
        "test:ci:full": "npm run test:ci && npm run test:e2e && npm run test:load",
        "validate:all": "node dist/validate-all.js",
        "validate:rules": "npx tsx src/validate-rules.ts",
        "validate:ci-yaml": "npx tsx src/validate-ci-yaml.ts",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "lint:regex": "npx tsx src/lint-regex.ts",
    "test:eslint-rules": "npx tsx src/test/test-eslint-rules.ts",
        "test": "npm run test:ci"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.0.0",
        "eslint": "^10.4.0",
        "js-yaml": "^4.1.1",
        "tsx": "^4.22.3",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.59.4"
    },
    "dependencies": {
        "terminal-kit": "^3.1.2"
    }
}
