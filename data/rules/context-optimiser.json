{
  "description": "Règles de compression de langage naturel en directives compactes pour LLM",
  "version": "1.1",
  "rules": [
    { "pattern": "\\bs['']il (?:te|vous) pla[iî]t\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\bsvp\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\bstp\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\bmerci\\s+(?:pour|de)\\s+(?:ton|votre|ta)\\s+[^\\s,;.!?]+[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\bmerci(?: beaucoup)?(?: d['']avance)?(?: encore)?\\b[,.\\s!]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\b(?:désol[ée](?: du dérangement)?|pardon|excuse[z]?[- ]moi)(?![\\p{L}\\p{N}_])[,.\\s!]*", "flags": "giu", "replacement": "", "reason": "desole" },
    { "pattern": "\\bbonjour\\b[,.\\s!]*", "flags": "gi", "replacement": "", "reason": "salutation" },
    { "pattern": "\\b(?:salut|coucou|hello|hi)\\b[,.\\s!]*", "flags": "gi", "replacement": "", "reason": "salutation" },
    { "pattern": "\\b(?:euh+|hum+|ben|bah|du coup|en fait|alors)\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "filler" },
    { "pattern": "\\bje pense que\\b", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "\\bj['']imagine que\\b", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "(?<=^|[.!?]\\s+)\\best[- ]ce[- ]que\\s+(?:tu|vous)\\s+(?:ne\\s+)?(?:peux|pouvez|pourrais|pourriez|pouvais|vas|allez|veux|voulez|voulais)\\s+", "flags": "gi", "replacement": "", "reason": "interrogatif→imperatif" },
    { "pattern": "\\b(?:peux[- ]tu|pourrais[- ]tu|pourriez[- ]vous)\\s+", "flags": "gi", "replacement": "", "reason": "requete→imperatif" },
    { "pattern": "\\bj['']aimerais (?:bien |vraiment )?(?:que tu )?", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\bje voudrais (?:bien |vraiment )?(?:que tu )?", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\bil faut (?:que tu |que )", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\bil faudrait (?:que tu |que )?", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\bplease\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\bthank(?:s| you)(?: very much)?\\b[,.\\s!]*", "flags": "gi", "replacement": "", "reason": "politesse" },
    { "pattern": "\\b(?:could|would) you(?: please)?\\s+", "flags": "gi", "replacement": "", "reason": "requete→imperatif" },
    { "pattern": "\\bcan you(?: please)?\\s+", "flags": "gi", "replacement": "", "reason": "requete→imperatif" },
    { "pattern": "\\bI(?: would| ['']d) like (?:you )?to\\s+", "flags": "gi", "replacement": "Task: ", "reason": "volonte→tache" },
    { "pattern": "\\b(?:um+|uh+|well|so|like)\\b[,.\\s]*", "flags": "gi", "replacement": "", "reason": "filler" },
    { "pattern": "(?<=[.!?]\\s+)\\bet\\s+pour\\s+(?:ton|ta|mon|ma|votre|vos|tes|mes|ses|nos|son|sa|leur|leurs)\\s+\\w+\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "fragment-et" },
    { "pattern": "(?<![\\p{L}\\p{N}_])(?:bonne\\s+(?:journ[eé]e|continuation|soir[eé]e)|cordialement|bien\\s+[àa]\\s+(?:vous|toi)|[àa]\\s+bient[ôo]t|bon\\s+(?:week-end|w-e))\\b[,.!\\s]*", "flags": "giu", "replacement": "", "reason": "cloture" },
    { "pattern": "\\bn['']h[eé]site(?:z|s)?\\s+pas\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "cloture" },
    { "pattern": "\\bsi\\s+(?:tu|vous)\\s+(?:as|avez)\\s+(?:des\\s+)?questions\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "cloture" },
    { "pattern": "\\bje\\s+(?:reste|suis)\\s+(?:[àa]\\s+(?:ta|votre|la)\\s+(?:disposition|service))\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "cloture" },
    { "pattern": "(?<=^|[.!?]\\s+)(?:Voil[àa]|Voici)(?![\\p{L}\\p{N}_])[,.!\\s]*", "flags": "giu", "replacement": "", "reason": "filler" },
    { "pattern": "\\b(?:bref|en\\s+tout\\s+cas|quoi\\s+qu['']il\\s+en\\s+soit)\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "filler" },
    { "pattern": "(?:[àa]\\s+vrai[e]?\\s+dire|en\\s+r[eé]alit[eé])(?![\\p{L}\\p{N}_])[,.!\\s]*", "flags": "giu", "replacement": "", "reason": "filler" },
    { "pattern": "\\bj['']ai\\s+l['']impression\\s+que\\b", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "\\bil\\s+me\\s+semble\\s+que\\b", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "\\b(?:je\\s+)?crois?\\s+que\\b", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "(?:peut-[- ]?[êe]tre(?:\\s+que)?|[àa]\\s+peu\\s+pr[eè]s|environ|apparemment|sans\\s+doute|probablement)\\b[,.!\\s]*", "flags": "gi", "replacement": "", "reason": "hedging" },
    { "pattern": "\\bj'?(?:ai|aurais?)\\s+besoin(?:\\s+de)?(?:\\s+que\\s+(?:tu|vous)\\s+)?", "flags": "gi", "replacement": "", "reason": "causalite" },
    { "pattern": "\\bje\\s+veux\\s+(?:que\\s+(?:tu|vous)\\s+)?", "flags": "gi", "replacement": "", "reason": "causalite" },
    { "pattern": "\\b(?:il\\s+s'agit\\s+de|ce\\s+que\\s+je\\s+veux\\s+c['']est)\\s+", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\b(?:mon\\s+)?(?:objectif|but)\\s+(?:est\\s+)?de\\s+", "flags": "gi", "replacement": "Tâche : ", "reason": "volonte→tache" },
    { "pattern": "\\bje\\s+(?:voulais|voudrais)\\s+te\\s+(?:demander\\s+)?", "flags": "gi", "replacement": "", "reason": "interrogatif→imperatif" },
    { "pattern": "\\bje\\s+me\\s+demandais\\s+", "flags": "gi", "replacement": "", "reason": "interrogatif→imperatif" },
    { "pattern": "(?<=^|[.!?]\\s+)c['']est\\s+possible\\s+(?:de|que)\\s+", "flags": "gi", "replacement": "", "reason": "interrogatif→imperatif" },
    { "pattern": "\\b(?:temps\\s+d['']ex[eé]cution|execution\\s+time|duration|[Tt]ook)\\s*[:=]?\\s*\\d+\\.?\\d*\\s*(?:s|ms|sec|secondes?)\\s*", "flags": "gi", "replacement": "", "reason": "meta" },
    { "pattern": " +([,.;:!?])", "flags": "g", "replacement": "$1", "reason": "ponctuation" },
    { "pattern": "([,.;:!?]){2,}", "flags": "g", "replacement": "$1", "reason": "ponctuation-doublee" }
  ]
}
