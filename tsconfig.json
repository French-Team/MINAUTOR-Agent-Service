{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true,
        "types": ["node"]
    },
    "include": [
        "src",
        "eslint-rules"
    ],
    "exclude": [
        "node_modules",
        "dist",
        ".agents"
    ]
}